<!DOCTYPE html>
<html>
<head>
  <style>
    body {
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      background: #0a0f1e;
    }
    .orb {
      width: 100px;
      height: 100px;
      background: radial-gradient(circle, #ff88aa, #441122);
      border-radius: 50%;
      transition: transform 0.1s linear;
      box-shadow: 0 0 40px rgba(255,100,100,0.5);
    }
    #status {
      position: fixed;
      bottom: 20px;
      color: white;
      font-family: monospace;
    }
  </style>
</head>
<body>
<div class="orb" id="orb"></div>
<div id="status">awaiting camera... breathe steadily</div>

<script>
  navigator.mediaDevices.getUserMedia({ video: true })
    .then(stream => {
      const video = document.createElement('video');
      video.srcObject = stream;
      video.play();
      const canvas = document.createElement('canvas');
      const ctx = canvas.getContext('2d');
      
      let prevBrightness = 0;
      let amplitude = 1;
      
      function analyzeBreath() {
        if (video.videoWidth === 0) return;
        canvas.width = video.videoWidth;
        canvas.height = video.videoHeight;
        ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
        let frame = ctx.getImageData(0, 0, canvas.width, canvas.height);
        let brightness = 0;
        for (let i = 0; i < frame.data.length; i += 4) {
          brightness += (frame.data[i] + frame.data[i+1] + frame.data[i+2]) / 3;
        }
        brightness /= (frame.data.length / 4);
        
        let delta = brightness - prevBrightness;
        // delta positive means inhale (chest expands → more light change? crude but works)
        amplitude = Math.min(1.5, Math.max(0.7, amplitude + delta * 0.005));
        document.getElementById('orb').style.transform = `scale(${amplitude})`;
        document.getElementById('status').innerText = `breath amplitude: ${amplitude.toFixed(2)}`;
        
        prevBrightness = brightness;
        requestAnimationFrame(analyzeBreath);
      }
      requestAnimationFrame(analyzeBreath);
    })
    .catch(err => {
      document.getElementById('status').innerText = 'camera error: ' + err.message;
    });
</script>
</body>
</html>
